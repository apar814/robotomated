# ============================================================================
# Robotomated.com — Environment Variables
# Copy to .env.local and fill in your values
# ============================================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude AI Advisor)
ANTHROPIC_API_KEY=sk-ant-your-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (Subscriptions)
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_PRICE_ID=price_your-price-id
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Email (Resend)
RESEND_API_KEY=re_your-key

# Analytics (PostHog)
NEXT_PUBLIC_POSTHOG_KEY=phc_your-key

# Redis Cache (Upstash)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Error Monitoring (Sentry)
NEXT_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Affiliate Tags
AMAZON_ASSOCIATE_TAG=robotomated-20
IMPACT_BESTBUY_TAG=
IMPACT_BH_TAG=

# Firecrawl (Web scraping / data enrichment)
FIRECRAWL_API_KEY=fc-your-key

# Admin
ADMIN_EMAIL=admin@robotomated.com
ADMIN_SECRET=your-admin-secret

# Cron Jobs
CRON_SECRET=your-cron-secret
