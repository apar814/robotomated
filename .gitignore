!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# outreach output (generated CSVs with contact data)
scripts/output/*.csv

# env files
.env
.env.local
.env.production.local
.env.development.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.drift/
.superpowers/
.driftignore

